---
import { features } from "../../Data/features.js";
const total = features.length;
---

<section id="atuacao" class="py-16 bg-neutral">
  <div class="max-w-7xl mx-auto px-6 text-center">
    <h2 class="text-3xl font-bold uppercase text-[#313d25] mb-8">
      Áreas de Atuação
    </h2>

    <div class="relative py-3" id="carousel-outer" style="overflow-x: clip;">
      <div id="track" class="flex" style="gap: 24px">
        {features.map((feature) => (
          <div class="slide-item flex-shrink-0">
            <div class="p-12 bg-gray-50 rounded-xl shadow hover:shadow-md border border-gray-100 transition flex flex-col justify-center items-center text-center h-full">
              <h3 class="text-2xl text-[#313d25] font-semibold mb-4">{feature.title}</h3>
              <p class="text-gray-600 text-lg max-w-xl">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>

      <button
        id="prev-slide"
        class="absolute left-3 top-1/2 -translate-y-1/2 btn btn-circle bg-[#d4dfc8] border-none text-[#313d25] hover:bg-[#c2d0b4] z-10"
      >
        ❮
      </button>

      <button
        id="next-slide"
        class="absolute right-3 top-1/2 -translate-y-1/2 btn btn-circle bg-[#d4dfc8] border-none text-[#313d25] hover:bg-[#c2d0b4] z-10"
      >
        ❯
      </button>
    </div>
  </div>
</section>

<script define:vars={{ total }}>
  const outer = document.getElementById('carousel-outer');
  const track = document.getElementById('track');
  const GAP   = 24;
  const RATIO = 0.78;

  // Clone first and last slides for seamless infinite loop
  const origItems = [...track.children];
  track.appendChild(origItems[0].cloneNode(true));
  track.insertBefore(origItems[total - 1].cloneNode(true), origItems[0]);
  // Layout: [clone-last, slide0, slide1, ..., clone-first]

  let current      = 1;
  let transitioning = false;

  function cardWidth()  { return outer.offsetWidth * RATIO; }
  function stepSize()   { return cardWidth() + GAP; }
  function offsetFor(i) { return -i * stepSize() + (outer.offsetWidth - cardWidth()) / 2; }

  function setWidths() {
    const w = cardWidth();
    [...track.children].forEach(c => { c.style.width = w + 'px'; });
  }

  function moveTo(i, animate = true) {
    current = i;
    track.style.transition = animate ? 'transform 0.5s ease' : 'none';
    track.style.transform  = `translateX(${offsetFor(i)}px)`;
    if (!animate) transitioning = false;
  }

  track.addEventListener('transitionend', () => {
    transitioning = false;
    if (current === 0)           moveTo(total, false);
    else if (current === total + 1) moveTo(1, false);
  });

  // Defer init so the element has a real size (fixes mobile disappearing)
  requestAnimationFrame(() => {
    setWidths();
    moveTo(1, false);
  });

  document.getElementById('prev-slide').addEventListener('click', () => {
    if (transitioning) return;
    transitioning = true;
    moveTo(current - 1);
  });

  document.getElementById('next-slide').addEventListener('click', () => {
    if (transitioning) return;
    transitioning = true;
    moveTo(current + 1);
  });

  setInterval(() => {
    if (transitioning || isDragging) return;
    transitioning = true;
    moveTo(current + 1);
  }, 5000);

  window.addEventListener('resize', () => {
    setWidths();
    moveTo(current, false);
  });

  // --- Drag / swipe support ---
  let isDragging   = false;
  let dragStartX   = 0;
  let dragCurrentX = 0;
  const DRAG_THRESHOLD = 50;

  function onDragStart(x) {
    if (transitioning) return;
    isDragging   = true;
    dragStartX   = x;
    dragCurrentX = x;
    track.style.transition = 'none';
  }

  function onDragMove(x) {
    if (!isDragging) return;
    dragCurrentX = x;
    const delta = x - dragStartX;
    track.style.transform = `translateX(${offsetFor(current) + delta}px)`;
  }

  function onDragEnd() {
    if (!isDragging) return;
    isDragging = false;
    const delta = dragCurrentX - dragStartX;
    transitioning = true;
    if (Math.abs(delta) > DRAG_THRESHOLD) {
      moveTo(delta < 0 ? current + 1 : current - 1);
    } else {
      moveTo(current);
    }
  }

  // Mouse
  outer.addEventListener('mousedown', (e) => { onDragStart(e.clientX); });
  window.addEventListener('mousemove', (e) => { if (isDragging) onDragMove(e.clientX); });
  window.addEventListener('mouseup', () => onDragEnd());

  // Touch
  outer.addEventListener('touchstart', (e) => { onDragStart(e.touches[0].clientX); }, { passive: true });
  outer.addEventListener('touchmove',  (e) => { if (isDragging) onDragMove(e.touches[0].clientX); }, { passive: true });
  outer.addEventListener('touchend',   () => onDragEnd());
</script>

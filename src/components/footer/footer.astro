---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="bg-black text-white py-10">
  <div class="max-w-6xl mx-auto flex flex-col items-center gap-10 text-center">
    <!-- Sections -->
    <div
      class="flex flex-col md:flex-row md:justify-center md:gap-20 gap-10 w-full"
    >
      <!-- Services -->
      <div>
        <h6 class="footer-title text-white mb-3 uppercase font-bold">
          Serviços
        </h6>
        <a href="#atuacao" class="link link-hover text-white block">Sucessões e Planejamento Patrimonial</a>
        <a href="#atuacao" class="link link-hover text-white block">Processos Administrativos</a>
        <a href="#atuacao" class="link link-hover text-white block">Direito Empresarial</a>
      </div>

      <!-- Pages -->
      <div>
        <h6 class="footer-title text-white mb-3 uppercase font-bold">
          Páginas
        </h6>
        <a href={base} class="link link-hover text-white block">Início</a>
        <a href={`${base}artigos`} class="link link-hover text-white block">Artigos</a>
      </div>

      <!-- Contato -->
      <div>
        <h6 class="footer-title text-white mb-3 uppercase font-bold">Contato</h6>
        <p class="text-white block">WhatsApp: (41) 99219-7684</p>
        <p class="text-white block">E-mail: fernandafantinc@gmail.com</p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="text-white text-sm">
      &copy; {new Date().getFullYear()} FFC Advocacia. Todos os direitos reservados.
    </div>
  </div>
</footer>

---
import { getCollection } from "astro:content";
import Base from "../../../layouts/Base.astro";
import BlogCard from "../../../components/blog/BlogCard.astro";
import Pagination from "../../../components/blog/Pagination.astro";

export async function getStaticPaths() {
  const allArticles = await getCollection("articles");
  const sortedArticles = allArticles.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );

  const postsPerPage = 6;
  const totalPages = Math.ceil(sortedArticles.length / postsPerPage);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2; // pages 2, 3, 4...
    const start = (page - 1) * postsPerPage;
    return {
      params: { page: String(page) },
      props: {
        currentArticles: sortedArticles.slice(start, start + postsPerPage),
        currentPage: page,
        totalPages,
      },
    };
  });
}

const { currentArticles, currentPage, totalPages } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const paginationBase = `${base}artigos`;
---

<Base title={`Artigos — Página ${currentPage}`} meta_title={`Artigos | FFC`}>
  <section class="px-6 pt-32 pb-20 max-w-7xl mx-auto">
    <h1 class="text-center text-[#313d25] text-4xl font-extrabold uppercase tracking-[3px] mb-12">
      Artigos
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {currentArticles.map((article) => (
        <BlogCard article={article} />
      ))}
    </div>

    <Pagination currentPage={currentPage} totalPages={totalPages} paginationBase={paginationBase} />
  </section>
</Base>

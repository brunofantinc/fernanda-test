---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Breadcrumbs from "../../components/blog/Breadcrumbs.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, subtitle, date, image, author } = entry.data;
const formattedDate = new Date(date).toLocaleDateString("pt-BR", { day: "numeric", month: "long", year: "numeric" });
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Base title={title}>
  <article class="max-w-4xl mx-auto px-6 pt-32 pb-20">
{image && (
      <img
        src={image}
        alt={title}
        class="w-full h-96 object-cover rounded-2xl shadow mb-8"
      />
    )}

    <h1 class="text-3xl md:text-4xl font-bold text-[#313d25] mb-2">
      {title}
    </h1>

    {subtitle && (
      <p class="text-lg text-gray-500 font-medium italic mb-4">{subtitle}</p>
    )}

    <p class="text-gray-400 text-sm mb-2">{formattedDate}</p>

    {author && (
      <p class="text-gray-500 text-sm italic mb-8">{author}</p>
    )}

    <div class="prose prose-lg max-w-none text-gray-800">
      <Content />
    </div>

    <a
      href={`${base}artigos`}
      class="inline-block my-8 px-6 py-2 bg-[#0B2545] text-white rounded-full hover:bg-[#F9C74F] hover:text-[#0B2545] transition"
    >
      ← Voltar aos Artigos
    </a>
  </article>
</Base>
